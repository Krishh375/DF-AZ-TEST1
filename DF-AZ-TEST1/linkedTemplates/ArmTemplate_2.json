				"privateLinkResourceId": "[parameters('AzureSqlDatabase540_properties_privateLinkResourceId')]",
				"groupId": "[parameters('AzureSqlDatabase540_properties_groupId')]"
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/default/AzureSqlDatabase591')]",
			"type": "Microsoft.DataFactory/factories/managedVirtualNetworks/managedPrivateEndpoints",
			"apiVersion": "2018-06-01",
			"properties": {
				"privateLinkResourceId": "[parameters('AzureSqlDatabase591_properties_privateLinkResourceId')]",
				"groupId": "[parameters('AzureSqlDatabase591_properties_groupId')]"
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/default/CosmosDb')]",
			"type": "Microsoft.DataFactory/factories/managedVirtualNetworks/managedPrivateEndpoints",
			"apiVersion": "2018-06-01",
			"properties": {
				"privateLinkResourceId": "[parameters('CosmosDb_properties_privateLinkResourceId')]",
				"groupId": "[parameters('CosmosDb_properties_groupId')]",
				"fqdns": "[parameters('CosmosDb_properties_fqdns')]"
			},
			"dependsOn": []

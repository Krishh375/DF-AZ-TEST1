		{
			"name": "[concat(parameters('factoryName'), '/default/PrivateLinkService492')]",
			"type": "Microsoft.DataFactory/factories/managedVirtualNetworks/managedPrivateEndpoints",
			"apiVersion": "2018-06-01",
			"properties": {
				"privateLinkResourceId": "[parameters('PrivateLinkService492_properties_privateLinkResourceId')]",
				"groupId": "[parameters('PrivateLinkService492_properties_groupId')]",
				"fqdns": "[parameters('PrivateLinkService492_properties_fqdns')]"
			},
			"dependsOn": []
